# Engine pinning — fail install if Node/npm version doesn't match package.json
engine-strict=true

# Save exact versions for new dependencies (encourages deliberate upgrades)
save-exact=false

# Don't generate package-lock.json overrides we don't need
package-lock=true

# Fund downloads stay off in CI logs
fund=false
audit-level=moderate

# Reduce noise from optional native deps you don't need
# (e.g. `@napi-rs/canvas` for headless server deployments)
optional=true
