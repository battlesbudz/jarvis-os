entrypoint = "README.md"
modules = ["nodejs-22", "javascript", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3000

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["javascript_openai_ai_integrations:2.0.0", "google-calendar:1.0.0", "outlook:1.0.0", "google-mail:1.0.0", "javascript_anthropic_ai_integrations:2.0.0", "javascript_gemini_ai_integrations:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-backend.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"
waitForPort = 8081
ensurePreviewReachable = "/status"

[[workflows.workflow]]
name = "test"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsx server/agent/__tests__/manifestFilter.assert.ts && tsx server/agent/__tests__/integrationError.assert.ts && tsx server/agent/__tests__/selfHeal.assert.ts && tsx server/agent/__tests__/writeBudget.assert.ts && tsx server/agent/__tests__/mcp.assert.ts && tsx server/agent/__tests__/browserTabTools.test.ts && tsx server/agent/__tests__/toolCallHooks.test.ts && tsx server/agent/__tests__/outboundMiddleware.test.ts && tsx server/agent/__tests__/responseQuality.test.ts && tsx server/agent/__tests__/jobQueue.notifyJobComplete.test.ts && tsx server/agent/__tests__/buildFeatureJob.test.ts && tsx server/agent/__tests__/queryClassifier.test.ts && tsx server/agent/__tests__/coachBuildRouting.test.ts && tsx server/agent/__tests__/harnessAndroidRevision.test.ts && tsx server/agent/__tests__/harness.android.test.ts"

[userenv]

[userenv.shared]
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID = "464052645678-au43qstbkio1gc6foomqo1a40c9f5vpk.apps.googleusercontent.com"
GOOGLE_WEB_CLIENT_ID = "464052645678-au43qstbkio1gc6foomqo1a40c9f5vpk.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "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"
ANDROID_APK_URL = "https://github.com/battlesbudz/JarvisAi/releases/download/android-daemon-latest/jarvis-daemon.apk"

[userenv.production]
EXPO_PUBLIC_DOMAIN = "GameplanAI.replit.app"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000
