{
  "name": "jarvis-os",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "postinstall": "patch-package",
    "expo:dev": "npx expo start --localhost",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "node scripts/patch-coach-route.cjs && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "docs:audit": "node scripts/public-docs-audit.mjs",
    "ci:e2e:smoke": "node scripts/ci-e2e-smoke.mjs",
    "db:push": "node scripts/railway-db-push.mjs",
    "start": "npx expo start",
    "android:apk": "npx --yes eas-cli@latest build --platform android --profile apk",
    "android:aab": "npx --yes eas-cli@latest build --platform android --profile production",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "jarvis:doctor": "npx --yes tsx scripts/jarvis-doctor.ts",
    "jarvis:oauth:probe": "node scripts/probe-jarvis-codex-oauth.mjs",
    "jarvis:oauth:gateway": "node scripts/jarvis-local-oauth-gateway.mjs",
    "jarvis:oauth:gateway:doctor": "node scripts/jarvis-oauth-gateway-doctor.mjs",
    "jarvis:oauth:gateway:supervisor": "node scripts/jarvis-oauth-gateway-supervisor.mjs",
    "jarvis:oauth:gateway:watchdog": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/watch-jarvis-oauth-gateway.ps1",
    "jarvis:oauth:gateway:install-startup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-jarvis-oauth-gateway-startup.ps1",
    "jarvis:oauth:gateway:uninstall-startup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-jarvis-oauth-gateway-startup.ps1",
    "jarvis:desktop-daemon:watchdog": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/start-jarvis-desktop-daemon-watchdog.ps1",
    "jarvis:desktop-daemon:install-watchdog": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-jarvis-desktop-daemon-watchdog.ps1",
    "jarvis:desktop-daemon:uninstall-watchdog": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-jarvis-desktop-daemon-watchdog.ps1",
    "jarvis:desktop-connector:awaken": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/jarvis-desktop-connector-awaken.ps1",
    "jarvis:desktop-connector:test-config": "node scripts/__tests__/desktopConnectorTauriConfig.test.mjs",
    "jarvis:desktop-connector:build": "npm --prefix desktop-connector install && npm --prefix desktop-connector run build",
    "jarvis:qa:endpoints": "node scripts/deployed-jarvis-endpoint-qa.mjs",
    "jarvis:android-daemon:emulator-e2e": "node scripts/android-daemon-emulator-e2e.mjs",
    "jarvis:qa:composio": "node scripts/composio-production-smoke.mjs",
    "jarvis:qa:agent-sdk-hitl": "tsx scripts/agent-sdk-hitl-smoke.ts",
    "jarvis:qa:agent-sdk-golden": "tsx scripts/agent-sdk-golden-workflows.ts",
    "jarvis:qa:cleanup": "node scripts/deployed-jarvis-qa-cleanup.mjs",
    "jarvis:verify:brain-vector-db": "tsx scripts/verify-brain-vector-db.ts",
    "jarvis:verify:memory-vector-db": "tsx scripts/verify-memory-vector-db.ts",
    "jarvis:check": "npm run jarvis:doctor && npm test",
    "jarvis:android-daemon:config-check": "node scripts/android-unified-daemon-config-check.mjs",
    "test": "node scripts/run-agent-tests.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@composio/core": "^0.10.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/vector-icons": "^15.0.3",
    "@google/genai": "^1.50.1",
    "@inferencesh/sdk": "^0.5.16",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@napi-rs/canvas": "^0.1.99",
    "@openrouter/agent": "^0.7.0",
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
    "@react-native-async-storage/async-storage": "2.2.0",
