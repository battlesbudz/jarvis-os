# =============================================================
# GamePlan / Jarvis .gitignore
# =============================================================
# This file lists paths that should NOT be committed to the repo.
# Order matters: more specific rules win over general ones.

# -------------------------------------------------------------
# Dependencies
# -------------------------------------------------------------
node_modules/
jspm_packages/
bower_components/

# pnpm
.pnpm-store/

# -------------------------------------------------------------
# Build output
# -------------------------------------------------------------
# Server bundle (built from server/index.ts via esbuild).
# `server/` is the source — keep it. `server_dist/` is the build output — ignore it.
server_dist/

# Expo / React Native web build
.expo/
dist/
web-build/
static-build/
expo-env.d.ts

# Next.js dashboard
.next/
out/

# Tauri / desktop connector
desktop-connector/dist/
desktop-connector/sidecar/dist/
desktop-connector/sidecar/bundled-daemon/
desktop-connector/src-tauri/binaries/
desktop-connector/src-tauri/gen/
desktop-connector/src-tauri/target/

# TypeScript build info
*.tsbuildinfo

# Vercel
.vercel

# -------------------------------------------------------------
# Native build artifacts
# -------------------------------------------------------------
ios/
android/app/build/
android/build/
android/.gradle/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Android daemon (built locally, APK distributed via downloads/ or Releases)
android-daemon/app/build/
android-daemon/build/
android-daemon/.gradle/
android-daemon/local.properties

# -------------------------------------------------------------
# Local environment and secrets
# -------------------------------------------------------------
.env
.env*.local
.env.development
.env.production
.env.test
!.env.example

# -------------------------------------------------------------
# Runtime cache and working state
# -------------------------------------------------------------
.ytdlp-flags.json
.jarvis/
.superpowers/
.worktrees/
.cache/

# -------------------------------------------------------------
# Playwright test artifacts
# -------------------------------------------------------------
test-results/
playwright-report/
.playwright-mcp/
playwright/.cache/

# -------------------------------------------------------------
# Agent scratchpads and downloaded media
# -------------------------------------------------------------
# These are debug screenshots, pasted prompts, and ephemeral
# planning docs generated by Jarvis / Codex sessions. Keep the
# real source-of-truth docs in `docs/` instead.
attached_assets/

# Downloaded binaries (resolved at runtime by /api/download/apk)
# README.md is tracked; APK and other binaries are not.
downloads/*.apk
downloads/*.aab
downloads/*.ipa
downloads/*.zip
downloads/*.tar.gz

# -------------------------------------------------------------
# Logs and debug output
# -------------------------------------------------------------
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*
lerna-debug.*
logs/
*.pid
*.seed
*.pid.lock

# Metro
.metro-health-check*

# -------------------------------------------------------------
# Test coverage
# -------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -------------------------------------------------------------
# IDE and editor
# -------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~
.DS_Store
*.pem

# Cursor / Claude / other AI editor state
.cursor/
.aider*
.continue/

# -------------------------------------------------------------
# OS junk
# -------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -------------------------------------------------------------
# Misc
# -------------------------------------------------------------
.history/
.tonic/
tmp/
temp/
*.tmp
*.bak
*.orig
