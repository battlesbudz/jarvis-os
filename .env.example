# =============================================================
# GamePlan / Jarvis environment configuration
# =============================================================
# Copy this file to `.env` (or `.env.local`) and fill in real
# values. Anything marked [REQUIRED] will crash the app on boot
# if missing. Anything marked [OPTIONAL] has a sensible default
# baked into the code; set it only if you want to override.
#
# Conventions:
#   - Keys starting with EXPO_PUBLIC_ are inlined into the
#     client bundle at build time. Do not put server secrets here.
#   - Keys starting with JARVIS_ are Jarvis-specific runtime
#     config. They mostly have defaults; expose them only when
#     you need to override.
#   - Tokens / API keys here are READ by the Express server only.
#     The mobile/web client should reach the server over HTTPS and
#     never see these values directly.
#
# Where things come from in production:
#   - Replit:   set in the "Secrets" tab of your Repl
#   - Railway:  set per-service in the Variables tab
#   - Local:    .env (gitignored) or your shell rc file
# =============================================================


# ============================================================
# 1. CORE RUNTIME  [REQUIRED to start the server]
# ============================================================
# PostgreSQL connection string. Drizzle ORM reads this on boot
# and throws if missing. Local dev: postgres://postgres:postgres@localhost:5432/jarvis
DATABASE_URL=postgres://user:password@host:5432/dbname

# Port the Express server binds to. Defaults to 5000.
PORT=5000

# Host the server binds to. Defaults to 0.0.0.0 (Linux/Mac) or
# 127.0.0.1 (Windows). Set explicitly if you have a reverse proxy.
HOST=0.0.0.0

# NODE_ENV: development | production | test
NODE_ENV=development

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# If unset the server falls back to a dev secret — DO NOT do this in prod.
JWT_SECRET=replace-with-48-bytes-of-random-base64url

# Base URL the server tells clients to use. Used for OAuth
# callbacks, magic links, and APK download redirects.
# Examples:
#   http://localhost:5000
#   https://gameplanjarvisai.up.railway.app
APP_BASE_URL=http://localhost:5000

# Public hostname the mobile/web client connects to. Inlined
# into the Expo bundle at build time via EXPO_PUBLIC_*.
EXPO_PUBLIC_DOMAIN=localhost:5000
EXPO_PUBLIC_DEV_AUTH_URL=http://localhost:5000
JARVIS_API=http://localhost:5000


# ============================================================
# 2. AI PROVIDERS  [at least one REQUIRED]
# ============================================================
# Multiple providers are supported; only the one(s) you set
# keys for will be used. Provider order is determined by the
# model router (see server/agent/jarvisCoreRuntime.ts).

# --- OpenAI (primary) ---
# Used for: GPT-5-mini task planning, Whisper transcription,
# TTS "alloy", vision, embeddings.
OPENAI_API_KEY=sk-replace-me

# Optional per-user OpenAI credential profiles. Users can store either an API key
# or an OpenAI OAuth profile through Settings; provider is always "openai".
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# If unset, Jarvis falls back to JWT_SECRET for local/dev encryption.
# JARVIS_PROVIDER_AUTH_ENCRYPTION_KEY=replace-with-32-random-bytes
#
# OAuth endpoint values stay configurable because the public OpenAI docs do not
# currently define a stable third-party ChatGPT-subscription token endpoint.
# JARVIS_OPENAI_OAUTH_CLIENT_ID=replace-me
# JARVIS_OPENAI_OAUTH_CLIENT_SECRET=replace-me
# JARVIS_OPENAI_OAUTH_AUTHORIZATION_URL=https://example.openai-oauth-authorize-url
# JARVIS_OPENAI_OAUTH_TOKEN_URL=https://example.openai-oauth-token-url
# JARVIS_OPENAI_OAUTH_USERINFO_URL=https://example.openai-oauth-userinfo-url
# JARVIS_OPENAI_OAUTH_SCOPE=openid profile email
# JARVIS_OPENAI_OAUTH_REDIRECT_URI=http://127.0.0.1:1455/auth/callback
# JARVIS_OPENAI_PREFERRED_AUTH_TYPE=oauth
# JARVIS_OPENAI_AUTH_FALLBACK_ENABLED=false

# OpenAI-compatible endpoint override (Azure, OpenRouter proxy, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-replace-me

# --- Anthropic (optional) ---
# Used when ANTHROPIC_API_KEY is set and JARVIS_MODEL_PROVIDER
# selects Claude. Currently configured for some specialist agents.
# ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Google Gemini (optional) ---
# GOOGLE_GEMINI_API_KEY=replace-me
# AI_INTEGRATIONS_GEMINI_API_KEY=replace-me
# AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# --- OpenRouter (optional, multi-model aggregator) ---
# OPENROUTER_API_KEY=sk-or-replace-me

# --- Inference.sh (optional) ---
# INFSH_API_KEY=replace-me

# --- ModelRelay / custom (optional) ---
# MODELRELAY_API_KEY=replace-me
# MODELRELAY_BASE_URL=https://api.modelrelay.example.com
# MODEL_RELAY_API_KEY=replace-me
# MODEL_RELAY_BASE_URL=https://api.modelrelay.example.com

# --- Model routing ---
# Comma-separated provider fallback chain (e.g. "openai,anthropic,gemini").
# PROVIDER_FALLBACK_CHAIN=openai,anthropic

# Per-tier model overrides. Defaults are wired to GPT-5-mini / Claude / Gemini.
# JARVIS_DEFAULT_MODEL=gpt-5-mini
# JARVIS_CHEAP_MODEL=gpt-5-mini
# JARVIS_BALANCED_MODEL=gpt-5-mini
# JARVIS_SMART_MODEL=gpt-5-mini
# JARVIS_OPENAI_SMART_MODEL=gpt-5-mini
# JARVIS_OPENAI_BALANCED_MODEL=gpt-5-mini
# AGENT_SDK_MODEL=gpt-5-mini
# AGENT_SDK_CHEAP_MODEL=gpt-5-mini
# AGENT_SDK_BALANCED_MODEL=gpt-5-mini
# AGENT_SDK_SMART_MODEL=gpt-5-mini
# AGENT_SDK_MODEL_PROVIDER=openai
# JARVIS_MODEL_PROVIDER=openai

# Spend guardrails (USD per agent run).
# AGENT_SDK_MAX_COST=2.00
# AGENT_SDK_MAX_STEPS=40


# ============================================================
# 3. AUTH (Google + Microsoft)  [REQUIRED for sign-in]
# ============================================================
# Create a Google Cloud project, enable the APIs you want
# (Gmail, Calendar, Drive, People), then create OAuth clients:
#   - Web application   (used by server + web chat)
#   - iOS               (used by iOS build)
#   - Android           (used by Android build)
#   - Installed/Desktop (used by desktop daemon)
# Console: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_INSTALLED_CLIENT_SECRET=replace-me
GOOGLE_ANDROID_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=replace-me.apps.googleusercontent.com

# Inlined into the client bundle. Must match GOOGLE_WEB_CLIENT_ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=replace-me.apps.googleusercontent.com

# Microsoft / Outlook (optional — only needed if you sign in
# with Microsoft or sync Outlook Calendar/Mail).
# MICROSOFT_CLIENT_ID=replace-me
# MICROSOFT_CLIENT_SECRET=replace-me

# Dashboard protection. Any non-empty value enables it; the
# dashboard route checks Authorization: Bearer <DASHBOARD_SECRET>.
DASHBOARD_SECRET=replace-me-with-a-long-random-string


# ============================================================
# 4. CHANNELS  [each is OPTIONAL — only set what you use]
# ============================================================

# ---- 4a. Telegram ----
# Talk to @BotFather, run /newbot, paste the token here.
TELEGRAM_BOT_TOKEN=replace-me
# Optional: a second bot used for dev/staging so you don't
# collide with the prod bot's webhook.
# TELEGRAM_BOT_TOKEN_DEV=replace-me
# Set if you want the bot to verify inbound webhooks (recommended).
TELEGRAM_WEBHOOK_SECRET=replace-me
# Public URL of the Telegram Mini App (if you ship one).
# TELEGRAM_MINI_APP_URL=https://t.me/your_bot/app
# TELEGRAM_MINI_APP_BUTTON_TEXT=Open Jarvis
# TELEGRAM_WEB_APP_URL=https://t.me/your_bot/app
# ---- Telegram Codex proxy (advanced) ----
# If you proxy Telegram updates through your own Codex gateway:
# TELEGRAM_CODEX_PROXY_ENABLED=true
# TELEGRAM_CODEX_PROXY_PATH=/jarvis-telegram-proxy
# TELEGRAM_CODEX_PROXY_TARGET=http://localhost:5000
# TELEGRAM_CODEX_PROXY_ALLOW_REMOTE=false

# ---- 4b. Discord ----
# Create an application at https://discord.com/developers/applications
# then add a Bot user. Paste the bot token, application id, etc.
DISCORD_BOT_TOKEN=replace-me
DISCORD_APP_ID=replace-me
DISCORD_CLIENT_ID=replace-me
DISCORD_PUBLIC_KEY=replace-me
# Optional: a guild id you own for dev/test commands
# DISCORD_DEV_GUILD_ID=replace-me

# ---- 4c. Slack ----
# Create a Slack app, install to workspace, then:
SLACK_BOT_TOKEN=xoxb-replace-me
SLACK_SIGNING_SECRET=replace-me
SLACK_CLIENT_ID=replace-me
SLACK_CLIENT_SECRET=replace-me

# ---- 4d. WhatsApp (via Twilio) ----
# Provision a Twilio number with WhatsApp sender.
TWILIO_ACCOUNT_SID=ACreplace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+15555550100
TWILIO_WHATSAPP_NUMBER=+14155238886


# ============================================================
# 5. COMPOSIO (third-party tool integrations)
# ============================================================
# Composio gives Jarvis OAuth + tool wrappers for ~250 apps
# (Notion, Linear, HubSpot, Salesforce, etc.). Sign up at
# https://app.composio.dev, mint an API key, then set:
COMPOSIO_API_KEY=replace-me
# Where Composio should send OAuth callbacks after a user
# authorizes an integration:
COMPOSIO_CALLBACK_URL=https://your-domain.example.com/api/composio/callback
COMPOSIO_CALLBACK_BASE_URL=https://your-domain.example.com
# Secret used to validate OAuth callback state. Generate random.
COMPOSIO_CALLBACK_STATE_SECRET=replace-me
# Optional: pre-bound Gmail auth config id (saves users a step)
# COMPOSIO_GMAIL_AUTH_CONFIG_ID=ac_replace-me
# Optional: link to your Composio dashboard for the in-app UI
# COMPOSIO_DASHBOARD_URL=https://app.composio.dev


# ============================================================
# 6. ANDROID DAEMON  [OPTIONAL — only if you build the APK]
# ============================================================
# Public URL the in-app QR code points to for downloading the
# Android daemon APK. Typically a GitHub Releases URL.
# Examples:
#   https://github.com/battlesbudz/Gameplanjarvisai/releases/download/android-daemon-latest/jarvis-daemon.apk
#   https://your-cdn.example.com/jarvis-daemon.apk
ANDROID_APK_URL=https://example.com/path/to/jarvis-daemon.apk
JARVIS_ANDROID_DAEMON_APK_URL=https://example.com/path/to/jarvis-daemon.apk
JARVIS_ANDROID_DAEMON_VERSION_CODE=1
JARVIS_ANDROID_DAEMON_VERSION_NAME=1.0.1

# Main Jarvis app APK update settings.
JARVIS_ANDROID_APK_URL=https://example.com/path/to/jarvis-daemon.apk
JARVIS_ANDROID_RELEASE_URL=https://example.com/path/to/jarvis-daemon.apk

# Optional: in-app "check for update" manifest URLs.
# JARVIS_ANDROID_UPDATE_MANIFEST_URL=https://example.com/jarvis-update.json
# JARVIS_ANDROID_UPDATE_RELEASE_BASE=https://example.com/releases
# JARVIS_ANDROID_DAEMON_UPDATE_MANIFEST_URL=https://example.com/jarvis-daemon-update.json
# JARVIS_ANDROID_DAEMON_UPDATE_RELEASE_BASE=https://example.com/daemon-releases

# Android app signing keystore (base64 of the .jks file).
# Generate with:
#   base64 -w0 jarvis-app.keystore > keystore.b64
# Then paste the contents below.
JARVIS_APP_KEYSTORE_BASE64=base64-encoded-jarvis-app-keystore
JARVIS_APP_KEYSTORE_PASSWORD=your-jarvis-app-keystore-password
JARVIS_APP_KEY_ALIAS=your-jarvis-app-key-alias
JARVIS_APP_KEY_PASSWORD=your-jarvis-app-key-password

# Android daemon keystore (same generation procedure).
ANDROID_DAEMON_KEYSTORE_BASE64=base64-encoded-android-daemon-keystore
ANDROID_DAEMON_KEYSTORE_PASSWORD=your-android-daemon-keystore-password
ANDROID_DAEMON_KEY_ALIAS=your-android-daemon-key-alias
ANDROID_DAEMON_KEY_PASSWORD=your-android-daemon-key-password


# ============================================================
# 7. DESKTOP CONNECTOR / DAEMON  [OPTIONAL]
# ============================================================
# Where the desktop daemon writes its state file.
# JARVIS_DAEMON_STATE_PATH=/var/lib/jarvis/daemon-state.json
# Where the daemon sandboxes all file/process operations.
# JARVIS_DAEMON_ROOT=/home/you/jarvis-workspace
# Override which Chromium the Playwright MCP uses.
# CHROME_EXECUTABLE_PATH=/usr/bin/chromium
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Tauri (desktop connector) build target triple.
# TAURI_TARGET_TRIPLE=x86_64-pc-windows-msvc

# Windows-specific download URL for the desktop connector MSI.
# JARVIS_WINDOWS_CONNECTOR_DOWNLOAD_URL=https://example.com/jarvis-connector.msi
# JARVIS_WINDOWS_CONNECTOR_VERSION=1.0.0
# JARVIS_WINDOWS_CONNECTOR_SHA256=sha256-hex


# ============================================================
# 8. TUNNELS / NETWORKING  [OPTIONAL]
# ============================================================
# Tailscale is used by some Jarvis features (e.g. local-only
# proxy when deployed on Railway). Get a key from
# https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTHKEY=tskey-auth-replace-me
# TAILSCALE_EXE=/usr/local/bin/tailscale
# JARVIS_TAILSCALE_HTTP_PROXY_URL=http://localhost:8080

# Public base URL the OAuth gateway exposes to CodeX clients.
# JARVIS_OAUTH_GATEWAY_PUBLIC_URL=https://jarvis-gateway.example.com
# JARVIS_CODEX_GATEWAY_PUBLIC_URL=https://jarvis-gateway.example.com
# JARVIS_CODEX_GATEWAY_PROXY_URL=http://localhost:8787
# Shared secret the gateway uses to authenticate to your server.
# JARVIS_CODEX_GATEWAY_TOKEN=replace-me
# JARVIS_CODEX_GATEWAY_URL=http://localhost:8787


# ============================================================
# 9. YOUTUBE / MEDIA  [OPTIONAL]
# ============================================================
# YouTube transcript retrieval uses two strategies:
#   1. Innertube API (free, may rate-limit) — needs an API key
#   2. yt-dlp fallback (local, slower)
# Get an Innertube key from any third-party provider, e.g.
# https://github.com/deedy5/YouTube-Innertube-Api-Key
YOUTUBE_INNERTUBE_API_KEY=replace-me
# Cooldown between yt-dlp invocations (ms) to avoid rate limits.
# YTDLP_RATE_LIMIT_COOLDOWN_MS=60000

# Supadata (paid transcript service, optional fallback).
# SUPADATA_API_KEY=replace-me

# Local Whisper for Telegram voice notes (optional).
# Set LOCAL_WHISPER_ENABLED=true to enable; requires Python 3 + faster-whisper.
# LOCAL_WHISPER_ENABLED=false
# LOCAL_WHISPER_PYTHON=python3
# LOCAL_WHISPER_TIMEOUT_MS=60000

# Tavily / X / Exa / similar (web search providers).
# TAVILY_API_KEY=tvly-replace-me
# X_BEARER_TOKEN=AAAA-replace-me


# ============================================================
# 10. DEPLOYMENT INTEGRATIONS  [OPTIONAL]
# ============================================================
# These are read by `scripts/railway-*.mjs` and related helpers.
# Normally you set them via the Railway dashboard, not .env.

# RAILWAY_TOKEN — see https://railway.app/account/tokens
# RAILWAY_PROJECT_ID=replace-me
# RAILWAY_ENVIRONMENT=production
# RAILWAY_DATABASE_URL=postgres://...
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Vercel (used by some deploy helpers).
# VERCEL_TOKEN=replace-me

# Replit (legacy; if you still develop on Replit).
# REPLIT_CONNECTORS_HOST=integrations.replit.com
# REPLIT_CONNECTORS_HOSTNAME=integrations.replit.com
# REPLIT_DEV_DOMAIN=your-repl.username.repl.dev
# REPLIT_DOMAINS=your-repl.username.repl.dev
# REPLIT_INTERNAL_APP_DOMAIN=
# REPL_ID=replace-me
# REPL_IDENTITY=replace-me
# WEB_REPL_RENEWAL=allow


# ============================================================
# 11. JARVIS RUNTIME TUNING  [OPTIONAL — has safe defaults]
# ============================================================
# These are knobs the team uses while developing Jarvis. You
# almost never need to touch them in production.

# Core runtime
# ENABLE_JARVIS_CORE_RUNTIME=true
# ENABLE_AGENT_SDK_RUNNER=true
# JARVIS_LEAN_CONTEXT=true
# JARVIS_LEAN_CONTEXT_CHAR_LIMIT=8000
# JARVIS_LEAN_CONTEXT_HISTORY_MESSAGES=8
# JARVIS_BRAIN_PROJECTION=enabled
# JARVIS_BRAIN_RETRIEVAL=hybrid
# JARVIS_MODEL_ROUTING=auto
# JARVIS_MODEL_ROUTING_MAX_CHARS=16000
# JARVIS_DISABLE_DIRECT_OPENAI=false
# JARVIS_INBOX_TRIAGE_ENABLED=true
# JARVIS_DAEMON_PLATFORM=auto
# JARVIS_TRUST_LOCAL_GATEWAY_RPC=false
# JARVIS_TEST_ALLOW_DIRECT_PROVIDER=false

# Codex app server
# JARVIS_CODEX_APP_SERVER_ENABLED=true
# JARVIS_CODEX_APP_SERVER_PREWARM=true
# JARVIS_CODEX_APP_SERVER_PREWARM_DELAY_MS=2000
# JARVIS_CODEX_APP_SERVER_WARMUP_TIMEOUT_MS=30000
# JARVIS_CODEX_APP_SERVER_SERVICE_TIER=auto
# JARVIS_CODEX_APP_SERVER_ARGS=
# JARVIS_CODEX_RUNTIME=app-server
# JARVIS_CODEX_COMMAND=codex
# JARVIS_CODEX_EXEC_TIMEOUT_MS=120000

# Codex daemon
# JARVIS_CODEX_DAEMON_ENABLED=false
# JARVIS_CODEX_DAEMON_TIMEOUT_MS=60000
# JARVIS_CODEX_DAEMON_APP_SERVER_ENABLED=false
# JARVIS_CODEX_DAEMON_APP_SERVER_TIMEOUT_MS=60000
# JARVIS_CODEX_OAUTH_ENABLED=true
# JARVIS_CODEX_OAUTH_SKIP_CHECK=false

# Codex gateway
# JARVIS_OAUTH_GATEWAY_ENTRY=server
# JARVIS_OAUTH_GATEWAY_HEALTH_INTERVAL_MS=30000
# JARVIS_OAUTH_GATEWAY_HEALTH_TIMEOUT_MS=5000
# JARVIS_OAUTH_GATEWAY_MAX_LOCAL_FAILURES=3
# JARVIS_OAUTH_GATEWAY_MAX_PUBLIC_FAILURES=3
# JARVIS_OAUTH_GATEWAY_MAX_RESTART_DELAY_MS=60000
# JARVIS_OAUTH_GATEWAY_RESTART_DELAY_MS=5000
# JARVIS_OAUTH_GATEWAY_RESTART_ON_PUBLIC_FAILURE=true
# JARVIS_OAUTH_GATEWAY_REPAIR_PUBLIC_FUNNEL=true
# JARVIS_OAUTH_GATEWAY_STARTUP_GRACE_MS=15000
# JARVIS_OAUTH_GATEWAY_STRICT_PUBLIC_CHECK=false
# JARVIS_OAUTH_GATEWAY_SUPERVISED=true
# JARVIS_OAUTH_GATEWAY_ALLOW_FULL_SERVER=false
# JARVIS_OAUTH_GATEWAY_LOG_DIR=./logs/oauth-gateway
# JARVIS_OAUTH_GATEWAY_PUBLIC_DNS_SERVERS=1.1.1.1,8.8.8.8

# Agent session compaction
# AGENT_SESSION_TTL_HOURS=24
# AGENT_SESSION_KEEP_RECENT_TURNS=6
# AGENT_SESSION_COMPACT_MESSAGES=24
# AGENT_SESSION_SUMMARY_CHARS=600
# AGENT_SESSION_SUMMARY_LOAD_CHARS=2400
# AGENT_SESSION_SUMMARY_LOAD_COUNT=3

# Orchestrator
# ORCHESTRATOR_MAX_RETRIES=3
# CREW_BATCH_MAX=8

# Telegram batching / timeouts
# TELEGRAM_MESSAGE_BATCH_WINDOW_MS=400
# TELEGRAM_REPLY_TIMEOUT_MS=30000
# TELEGRAM_QUICK_ACTIONS_ENABLED=true


# ============================================================
# 12. INTERNAL QA / SMOKE  [DO NOT set in production]
# ============================================================
# Used by the scripts/jarvis:qa:* smoke tests. Should never
# be set in a real deploy.
# JARVIS_QA_BASE_URL=http://localhost:5000
# JARVIS_QA_AUTH_TOKEN=replace-me
# JARVIS_QA_RUN_CHAT=true
# JARVIS_QA_CHAT_PROMPT=ping
# JARVIS_QA_CLEANUP_TITLE=jarvis-qa-cleanup
# JARVIS_QA_CLEANUP_DELIVERABLE_TITLE=jarvis-qa-cleanup-deliverable
# JARVIS_QA_CLEANUP_MARKERS=jarvis-qa-cleanup
# JARVIS_ADMIN_SECRET=replace-me
# JARVIS_DOCTOR_USER_ID=replace-me


# ============================================================
# 13. MISC / EXPERIMENTAL  [OPTIONAL]
# ============================================================
# Default timezone for users who haven't set one. IANA name.
# DEFAULT_USER_TIMEZONE=America/New_York

# Data directory (defaults to ./data).
# JARVIS_DATA_DIR=./data

# Pair code (six digits) used by desktop daemon first connect.
# JARVIS_PAIR_CODE=123456

# ElevenLabs TTS (optional alternative to OpenAI TTS).
# ELEVENLABS_API_KEY=replace-me

# GitHub (for /api/integrations/github routes — PRs, CI status, etc.).
# GITHUB_CLIENT_ID=Iv1.replace-me
# GITHUB_CLIENT_SECRET=replace-me

# Staging/prod toggles
# PROD_URL=https://gameplanjarvisai.up.railway.app
# SOURCE_USER_ID=replace-me
# DEST_USER_ID=replace-me
# SEED_USER_ID=replace-me
