# Public client configuration
EXPO_PUBLIC_DOMAIN=your-domain.example.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
ANDROID_APK_URL=https://example.com/path/to/jarvis-daemon.apk
JARVIS_API=http://localhost:5000

# Server and dashboard secrets
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_INSTALLED_CLIENT_SECRET=your-google-installed-client-secret
DASHBOARD_SECRET=your-dashboard-secret
YOUTUBE_INNERTUBE_API_KEY=your-youtube-innertube-api-key

# Android app signing
JARVIS_APP_KEYSTORE_BASE64=base64-encoded-jarvis-app-keystore
JARVIS_APP_KEYSTORE_PASSWORD=your-jarvis-app-keystore-password
JARVIS_APP_KEY_ALIAS=your-jarvis-app-key-alias
JARVIS_APP_KEY_PASSWORD=your-jarvis-app-key-password

# Android daemon signing
ANDROID_DAEMON_KEYSTORE_BASE64=base64-encoded-android-daemon-keystore
ANDROID_DAEMON_KEYSTORE_PASSWORD=your-android-daemon-keystore-password
ANDROID_DAEMON_KEY_ALIAS=your-android-daemon-key-alias
ANDROID_DAEMON_KEY_PASSWORD=your-android-daemon-key-password
